@unpublished{aboutajdine2026trade,
  title    = {Trade Rationing and Productivity Convergence},
  author   = {Aboutajdine, Samya and Degorce, Victor},
  year     = {2026},
  note     = {Work in progress},
  abstract = {This paper studies the role of postwar industrial policy in Europe's productivity convergence between the 1940s and 1970s. We construct a new archival dataset on highly disaggregated trade rationing policies implemented by 18 European countries during the postwar period. Because import restrictions were lifted gradually, unevenly, and at the product level over several decades, this setting provides novel empirical variation to identify the effects of infant industry protection on industrial development and productivity growth. Using newly collected archival data, we examine whether sectors exposed to longer-lasting trade protection experienced differential productivity dynamics, relative to less protected sectors. The staggered removal of rationing policies across industries and countries allows us to isolate the causal effects of protection from broader macroeconomic trends associated with postwar reconstruction. To interpret the empirical findings, we develop a quantitative model of industrialization and structural transformation under sector-specific trade restrictions. The model is used to quantify the contribution of rationing policies to Europe's postwar productivity convergence and to compare these effects to alternative mechanisms emphasized in the literature, in particular to post-war capital accumulation as the primary driver of convergence.},
  selected = {true}
}

